pipeline {
  agent any
  parameters {
    string(name: 'DEPLOY_ENV', defaultValue: 'staging')
    string(name: 'branch', defaultValue: 'main')
  }
  environment {
    IMAGE = "ghangaon/deployiq-app"
    REGISTRY_CRED = 'dockerhub-credentials'
  }
  stages {
    stage('Checkout') {
      steps {
        echo "=== STAGE 1: CHECKOUT ==="
        echo "Branch: ${params.branch} | Env: ${params.DEPLOY_ENV}"
        sh 'git log --oneline -3'
      }
    }
    stage('Build Docker Image') {
      steps {
        echo "=== STAGE 2: BUILD DOCKER IMAGE ==="
        sh """
          docker build -t ${IMAGE}:${BUILD_NUMBER} app/
          docker tag ${IMAGE}:${BUILD_NUMBER} ${IMAGE}:latest
          docker images | grep deployiq-app
          echo "Built: ${IMAGE}:${BUILD_NUMBER}"
        """
      }
    }
    stage('Security Scan') {
      steps {
        echo "=== STAGE 3: TRIVY SECURITY SCAN ==="
        sh """
          docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock \
            aquasec/trivy image \
            --exit-code 0 \
            --severity HIGH,CRITICAL \
            --no-progress \
            ${IMAGE}:latest || true
          echo "Security scan complete"
        """
      }
    }
    stage('Push to Docker Hub') {
      steps {
        echo "=== STAGE 4: PUSH TO DOCKER HUB ==="
        withCredentials([usernamePassword(
          credentialsId: "${REGISTRY_CRED}",
          usernameVariable: 'DOCKER_USER',
          passwordVariable: 'DOCKER_PASS'
        )]) {
          sh """
            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
            docker push ${IMAGE}:${BUILD_NUMBER}
            docker push ${IMAGE}:latest
            docker logout
            echo "Pushed: ${IMAGE}:${BUILD_NUMBER}"
          """
        }
      }
    }
    stage('Deploy Staging') {
      steps {
        echo "=== STAGE 5: DEPLOY TO STAGING ==="
        sh """
          docker stop deployiq-staging || true
          docker rm deployiq-staging || true
          docker run -d \
            --name deployiq-staging \
            -p 8090:80 \
            --restart unless-stopped \
            ${IMAGE}:latest
          sleep 3
          STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:8090)
          echo "Staging live on port 8090 — HTTP \$STATUS"
        """
      }
    }
    stage('Smoke Test') {
      steps {
        echo "=== STAGE 6: SMOKE TEST ==="
        sh """
          HTTP=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:8090)
          echo "App response: HTTP \$HTTP"
          [ "\$HTTP" = "200" ] && echo "Smoke test PASSED!" || echo "App returned HTTP \$HTTP"
        """
      }
    }
  }
  post {
    success { echo "PIPELINE SUCCESS — ${IMAGE}:${BUILD_NUMBER} deployed to staging!" }
    failure { echo "PIPELINE FAILED — check logs above" }
  }
}
